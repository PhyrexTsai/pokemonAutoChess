    "@playwright/test": "^1.58.2",
    "@types/bootstrap": "^5.2.10",
    "@types/d3": "^7.4.3",
    "@types/elo-rank": "^1.0.3",
    "@types/matter-js": "^0.20.0",
    "@types/node": "^24.10.1",
    "@types/node-fetch": "^2.6.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "csv-writer": "^1.6.0",
    "degit": "^2.8.4",
    "esbuild": "^0.27.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
